# editor / python junk
**/__pycache__
**/.vscode
**/.DS_Store

# bulky data & media (regenerable, not needed in git)
**/*.mp4
**/*.avi
**/*.mov
**/*.csv
**/*.xlsx
**/*.pkl
**/*.npy
**/*.npz
**/*.txt
**/*.json
**/*.log
**/*.zip
**/metric_3d
**/metric_2d

# Figures, bibliography and class files are regenerable / managed elsewhere.
**/*.png
**/*.bib
**/*.cls


# Scene homographies are small and needed to render the spatial-uncertainty
# overlay; track them (videos stay ignored -- re-fetch via planar/assets/download_videos.sh).
!planar/assets/homographies/
!planar/assets/homographies/*.txt

# Backup snapshots (e.g. metric/*.json.de100bak kept locally for revert to de=1.0).
**/*.bak
**/*.de100bak

# Exploratory work that backs decisions but is not part of the paper:
#  - planar/_scratch/      : oracle/ICS experiment + delta_evade / w_safety sweep scripts
#  - planar/metric_oracle/ : their outputs (reports, figures, raw pickles)
#  - **/T_RO2026/          : local paper-sync copies of tables (the paper repo is external)
planar/_scratch/
planar/metric_oracle/
**/T_RO2026/

# Raw SDD dataset (downloaded, large) -- not tracked; re-fetch per docs/HANDOFF.md.
SDD/
sdd_data/

# ...but DO track the SDD analysis OUTPUTS (figures / per-cell result data) produced
# by analyze_spatial_uncertainty_ext.py at the repo root.
!sdd_*_overlay.png
!sdd_*_diag.png
!sdd_*_cells.npz
