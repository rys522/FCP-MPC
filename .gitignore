# editor / python junk
**/__pycache__
**/.vscode

# bulky data & media (regenerable, not needed in git)
**/*.mp4
**/*.avi
**/*.mov
**/*.csv
**/*.xlsx
**/*.pkl
**/*.npy
**/*.npz
**/*.txt
**/*.json
**/metric_3d
**/metric_2d

# Figures, bibliography and class files are ignored everywhere EXCEPT the
# paper folder (T_RO2026), whose assets the LaTeX build needs.
**/*.png
**/*.bib
**/*.cls
!T_RO2026/*.png
!T_RO2026/*.bib
!T_RO2026/*.cls

# Scene homographies are small and needed to render the spatial-uncertainty
# overlay; track them (videos stay ignored -- re-fetch via assets/download_videos.sh).
!assets/homographies/
!assets/homographies/*.txt
