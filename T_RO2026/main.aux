\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces The residual field is approximately \emph  {time-invariant}. Per-cell residual means estimated from temporally disjoint early (\textbf  {left}) and late (\textbf  {middle}) halves of \texttt  {univ} agree closely (\textbf  {right}; cell-mean correlation $r=0.71$), indicating the field is a stable property of the scene rather than of a particular time --- the premise that lets an offline-calibrated envelope transfer online.}}{10}{figure.3}\protected@file@percent }
\newlabel{fig:fcp_stationarity}{{3}{10}{The residual field is approximately \emph {time-invariant}. Per-cell residual means estimated from temporally disjoint early (\textbf {left}) and late (\textbf {middle}) halves of \texttt {univ} agree closely (\textbf {right}; cell-mean correlation $r=0.71$), indicating the field is a stable property of the scene rather than of a particular time --- the premise that lets an offline-calibrated envelope transfer online}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces The residual score field is \emph  {low-rank}. \textbf  {Left:} cumulative variance explained by the leading functional principal components on each ETH--UCY scene; $5$--$7$ components already reach $90\%$ (dashed) on most scenes. \textbf  {Right:} the leading eigenfunction $\psi _1$ (\texttt  {univ}), a smooth scene-frame spatial mode. The low effective dimension is what lets the envelope be learned offline.}}{10}{figure.4}\protected@file@percent }
\newlabel{fig:fcp_lowrank}{{4}{10}{The residual score field is \emph {low-rank}. \textbf {Left:} cumulative variance explained by the leading functional principal components on each ETH--UCY scene; $5$--$7$ components already reach $90\%$ (dashed) on most scenes. \textbf {Right:} the leading eigenfunction $\psi _1$ (\texttt {univ}), a smooth scene-frame spatial mode. The low effective dimension is what lets the envelope be learned offline}{figure.4}{}}
